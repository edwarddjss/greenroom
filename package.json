{
  "name": "greenroom",
  "version": "0.1.0",
  "private": true,
  "description": "greenroom - self-hosted Spotify-to-Discord streaming bot with a Windows desktop client",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:engine": "pnpm --filter @greenroom/engine dev",
    "guides:record": "node scripts/record-guides.mjs",
    "win:dev": "bash scripts/win-dev.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "playwright": "^1.60.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-llama-cpp"
    ]
  }
}
