{
  "name": "@greenroom/desktop",
  "version": "0.1.15",
  "private": true,
  "description": "greenroom desktop client (Electron) for Windows",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/build.mjs",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "package": "node scripts/package.mjs"
  },
  "build": {
    "appId": "app.greenroom.desktop",
    "productName": "greenroom",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "package.json",
      "!**/@node-llama-cpp/win-x64-cuda*/**",
      "!**/@node-llama-cpp/win-x64-vulkan/**",
      "!**/@node-llama-cpp/win-arm64/**"
    ],
    "extraResources": [
      {
        "from": "resources/bin/ffmpeg.exe",
        "to": "bin/ffmpeg.exe"
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "greenroom-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "greenroom"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "edwarddjss",
        "repo": "greenroom",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@greenroom/engine": "workspace:*",
    "@greenroom/shared": "workspace:*",
    "electron-updater": "^6.3.9",
    "node-vibrant": "^4.0.4",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
