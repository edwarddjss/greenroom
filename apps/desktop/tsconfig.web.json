{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "noEmit": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"]
}
