# ====================================================================
# Discord Settings
# ====================================================================
# Your Discord Bot Token (from Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord Application/Client ID (from General Information -> Application ID)
DISCORD_CLIENT_ID=your_discord_client_id_here

# Optional: Server/Guild ID for instant command registration (development mode)
# If left blank, commands will register globally (can take up to an hour)
DISCORD_GUILD_ID=

# ====================================================================
# Spotify Settings
# ====================================================================
# Spotify Developer Credentials (from Spotify Developer Dashboard -> App -> Settings)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Must match the Redirect URI set in the Spotify Developer Dashboard settings
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ====================================================================
# Server & Audio Settings
# ====================================================================
# The port where the Spotify OAuth authentication server will listen
PORT=8888

# The platform hosting the bot ('windows' or 'linux')
AUDIO_PLATFORM=windows

# The exact name of the Virtual Loopback Device.
# Windows: CABLE Output (VB-Audio Virtual Cable)
# Linux: null.monitor or alsa_output.pci-0000_00_1b.0.analog-stereo.monitor
AUDIO_DEVICE=CABLE Output (VB-Audio Virtual Cable)

# Optional: Target Spotify Connect device name. 
# If set, the bot will automatically try to find and route playback to this device.
# If empty, the bot will automatically control the first available computer device.
SPOTIFY_TARGET_DEVICE_NAME=
